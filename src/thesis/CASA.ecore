        eType="#//Component" eOpposite="#//Component/realizes"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="processes" upperBound="-1"
        eType="#//NonPersonalData" eOpposite="#//NonPersonalData/processedBy"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="FuncPersData" eSuperTypes="#//Function">
