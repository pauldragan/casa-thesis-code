  <eClassifiers xsi:type="ecore:EClass" name="RequestTimestamps" eSuperTypes="#//PersonalData"/>
  <eClassifiers xsi:type="ecore:EClass" name="Data" abstract="true">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="NonPersonalData" eSuperTypes="#//Data">
    <eStructuralFeatures xsi:type="ecore:EReference" name="processedBy" upperBound="-1"
        eType="#//Function" eOpposite="#//Function/processes"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Purpose" abstract="true">
    <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
      <details key="constraints" value="UniquePurposes"/>
    </eAnnotations>
    <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot">
      <details key="UniquePurposes" value="&#xA;&#x9;&#x9;&#x9;Purpose.allInstances() -> isUnique(p | p.name)"/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="ofFunction" upperBound="-1"
        eType="#//FuncPersData" eOpposite="#//FuncPersData/has"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Component">
    <eStructuralFeatures xsi:type="ecore:EReference" name="realizes" upperBound="-1"
        eType="#//Function" eOpposite="#//Function/realizedBy"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="affectedBy" upperBound="-1"
        eType="#//Vulnerability" eOpposite="#//Vulnerability/affects"/>
