  <eClassifiers xsi:type="ecore:EClass" name="Vulnerability">
    <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
      <details key="constraints" value="UniqueVulnerabilities"/>
    </eAnnotations>
    <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot">
      <details key="UniqueVulnerabilities" value="&#xA;&#x9;&#x9;&#x9;Vulnerability.allInstances() -> isUnique(v | v.cveName)"/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="cveName" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="affects" upperBound="-1"
        eType="#//Component" eOpposite="#//Component/affectedBy"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="describedBy" lowerBound="1"
        eType="#//CVSSVector" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="causes" upperBound="-1"
        eType="#//Risk" eOpposite="#//Risk/causedBy"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="isEnabled" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean"
        defaultValueLiteral="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="CVSSVector">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="attackVector" eType="#//CVSS/AttackVector"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="attackComplexity" eType="#//CVSS/AttackComplexity"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="scope" eType="#//CVSS/Scope"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="privilegesRequired" eType="#//CVSS/PrivilegesRequired"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="userInteraction" eType="#//CVSS/UserInteraction"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="exploitCodeMaturity" eType="#//CVSS/ExploitCodeMaturity"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="reportConfidence" eType="#//CVSS/ReportConfidence"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="confidentialityImpact"
        eType="#//CVSS/ConfidentialityImpact"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="integrityImpact" eType="#//CVSS/IntegrityImpact"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="availabilityImpact" eType="#//CVSS/AvailabilityImpact"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="remediationLevel" eType="#//CVSS/RemediationLevel"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="confidentialityRequirement"
        eType="#//CVSS/ConfidentialityRequirement"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="integrityRequirement" eType="#//CVSS/IntegrityRequirement"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="availabilityRequirement"
        eType="#//CVSS/AvailabilityRequirement"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Risk">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="level" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EDouble"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="affects" lowerBound="1"
        eType="#//DataSubject" eOpposite="#//DataSubject/affectedBy"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="causedBy" upperBound="-1"
        eType="#//Vulnerability" eOpposite="#//Vulnerability/causes"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="System">
    <eStructuralFeatures xsi:type="ecore:EReference" name="functions" upperBound="-1"
        eType="#//Function" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="datas" upperBound="-1"
        eType="#//Data" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="dataSubjects" upperBound="-1"
        eType="#//DataSubject" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="vulnerabilities" upperBound="-1"
        eType="#//Vulnerability" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="components" upperBound="-1"
        eType="#//Component" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="purposes" upperBound="-1"
        eType="#//Purpose" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="RedisComponent" eSuperTypes="#//Component"/>
  <eClassifiers xsi:type="ecore:EClass" name="FilesystemComponent" eSuperTypes="#//Component"/>
  <eClassifiers xsi:type="ecore:EClass" name="Postgresql" eSuperTypes="#//Component"/>
  <eSubpackages name="CVSS" nsURI="http://www.casa.com/cvss" nsPrefix="casa.cvss">
    <eClassifiers xsi:type="ecore:EEnum" name="AttackVector">
      <eLiterals name="Network" literal="N"/>
      <eLiterals name="Adjacent" value="1" literal="A"/>
      <eLiterals name="Local" value="2" literal="L"/>
      <eLiterals name="Physical" value="3" literal="P"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EEnum" name="AttackComplexity">
      <eLiterals name="Low" literal="L"/>
      <eLiterals name="High" value="1" literal="H"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EEnum" name="Scope">
      <eLiterals name="Unchanged" literal="U"/>
      <eLiterals name="Changed" value="1" literal="C"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EEnum" name="PrivilegesRequired">
      <eLiterals name="None" literal="N"/>
      <eLiterals name="Low" value="1" literal="L"/>
      <eLiterals name="High" value="2" literal="H"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EEnum" name="UserInteraction">
      <eLiterals name="None" literal="N"/>
      <eLiterals name="Required" value="1" literal="R"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EEnum" name="ExploitCodeMaturity">
      <eLiterals name="NotDefined" literal="X"/>
      <eLiterals name="High" value="1" literal="H"/>
      <eLiterals name="Functional" value="2" literal="F"/>
      <eLiterals name="ProofOfConcept" value="3"/>
      <eLiterals name="Unproven" value="4" literal="U"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EEnum" name="ReportConfidence">
      <eLiterals name="NotDefined" literal="X"/>
      <eLiterals name="Confirmed" value="1" literal="C"/>
      <eLiterals name="Reasonable" value="2" literal="R"/>
      <eLiterals name="Unknown" value="3" literal="U"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EEnum" name="ConfidentialityImpact">
      <eLiterals name="High" literal="H"/>
      <eLiterals name="Low" value="1" literal="L"/>
      <eLiterals name="None" value="3" literal="N"/>
