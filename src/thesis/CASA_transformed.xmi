<?xml version="1.0" encoding="ASCII"?>
<casa:System
    xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:casa="http://www.casa.com"
    xsi:schemaLocation="http://www.casa.com CASA.ecore">
  <functions
      name="ServeContentFunction"
      realizedBy="//@components.0"/>
  <functions
      xsi:type="casa:FuncPersData"
      name="ServeStandardAdsFunction"
      realizedBy="//@components.0 //@components.1"
      processesPersData="//@datas.0"
      has="//@purposes.0"/>
  <datas xsi:type="casa:PersonalData"
      name="UsersData"
      identifies="//@dataSubjects.0"
      processedBy="//@functions.1"
      subjectOfConsent="//@dataSubjects.0/@gives.0"/>
  <dataSubjects
      identifiedBy="//@datas.0"
      name="SWIMUsers">
    <gives forPurpose="ServeStandardAdsPurpose"
        givenFor="//@purposes.0"
        forPersonalData="//@datas.0"/>
  </dataSubjects>
  <vulnerabilities
      cveName="CVE-2024-38816"
      affects="//@components.1">
    <describedBy
        integrityImpact="N"
        availabilityImpact="N"/>
  </vulnerabilities>
  <vulnerabilities
      cveName="CVE-2025-0650"
      affects="//@components.1">
    <describedBy
        attackComplexity="H"/>
  </vulnerabilities>
  <components
      realizes="//@functions.0 //@functions.1"
      name="SWIMComponent"/>
  <components
      realizes="//@functions.1"
      name="Component1"
      affectedBy="//@vulnerabilities.0 //@vulnerabilities.1"/>
  <purposes
      xsi:type="casa:PurposeConsent"
      name="ServeStandardAdsPurpose"
      ofFunction="//@functions.1"
      requires="//@dataSubjects.0/@gives.0"/>
  <purposes
      xsi:type="casa:PurposeConsent"
      name="ServeStandardAdsPurpose"/>
</casa:System>
